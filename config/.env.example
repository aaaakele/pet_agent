# DeepSeek API
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
THINKING_ENABLED=true

RESPONSE_TIMEOUT=15
RESPONSE_RETRY=2

DB_PATH=storage/chat.db
CHROMA_PATH=storage/chroma_db

MAX_HISTORY=50
PET_AVATAR_PATH=resources/wusaqi.gif

# QQ Bot (optional)
QQ_ENABLED=false
QQ_WS_HOST=127.0.0.1
QQ_WS_PORT=3001
QQ_WHITELIST=
